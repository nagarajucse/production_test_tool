# ==============================================================================
# Production Test Management System - Environment Configuration Template
# Copy this file to '.env' in production and configure accordingly.
# ==============================================================================

# ------------------------------------------------------------------------------
# TCP Server Configuration
# ------------------------------------------------------------------------------
SERVER_HOST=0.0.0.0
SERVER_PORT=5000
SERVER_TIMEOUT_SECONDS=30.0
SERVER_MAX_PACKET_SIZE_BYTES=1048576  # Max allowed size of JSON packet (1 MB)

# ------------------------------------------------------------------------------
# Database Configuration (PostgreSQL with SQLAlchemy Asyncpg)
# ------------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/test_manager

# ------------------------------------------------------------------------------
# Logging Configuration
# ------------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_MAX_BYTES=10485760  # 10 MB per file before rotating
LOG_BACKUP_COUNT=5      # Keep last 5 files of history
