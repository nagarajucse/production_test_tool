# ==============================================================================
# Production Test Management System - Environment Configuration
# ==============================================================================

# ------------------------------------------------------------------------------
# TCP Server Configuration (used by run_server.py / app/server/tcp.py)
# ------------------------------------------------------------------------------
SERVER_HOST=0.0.0.0
SERVER_PORT=5000
SERVER_TIMEOUT_SECONDS=30.0
# Max allowed size of JSON packet (1 MB)
SERVER_MAX_PACKET_SIZE_BYTES=1048576
# Max allowed concurrent client connections
SERVER_MAX_CONNECTIONS=1000

# ------------------------------------------------------------------------------
# Database Configuration
#
# TCP Server (async):   postgresql+asyncpg://...
# HTTP DMS Server (sync): postgresql://...
#
# The HTTP server (server/app.py) reads DATABASE_URL and requires the
# synchronous psycopg2 format (no +asyncpg suffix).
# Override this per-server if running both simultaneously.
# ------------------------------------------------------------------------------
DATABASE_URL=mysql+pymysql://root:root@localhost:3306/test_manager

# HTTP DMS Server sync database URL (psycopg2 — no asyncpg prefix)
# The server/config.py reads DATABASE_URL; set this to the sync URL when
# running the HTTP server independently.
# DATABASE_URL=postgresql://postgres:aratek123@localhost:5432/test_manager

# ------------------------------------------------------------------------------
# HTTP DMS Server Configuration (used by server/app.py)
# ------------------------------------------------------------------------------
# Maximum HTTP request body size in bytes (1 MB). Requests larger than
# this are automatically rejected with HTTP 413 Payload Too Large.
MAX_CONTENT_LENGTH=1048576

# ------------------------------------------------------------------------------
# Logging Configuration
# ------------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_DIR=logs
# 10 MB per file before rotating
LOG_MAX_BYTES=10485760
# Keep last 5 files of history
LOG_BACKUP_COUNT=5
