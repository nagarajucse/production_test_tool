# ==============================================================================
# DMS HTTP Server — Environment Configuration Template
#
# Copy this file to the PROJECT ROOT as '.env' and fill in your values.
# The server reads '.env' from the parent directory (one level above server/).
#
#   copy .env.example .env
#
# NEVER commit your actual .env file to version control.
# ==============================================================================

# ------------------------------------------------------------------------------
# HTTP Server Configuration
# ------------------------------------------------------------------------------
SERVER_HOST=0.0.0.0
SERVER_PORT=5000

# Maximum allowed HTTP request body size (bytes). Default: 1 MB.
# Requests larger than this are automatically rejected with HTTP 413.
MAX_CONTENT_LENGTH=1048576

# ------------------------------------------------------------------------------
# Database Configuration
# Use the synchronous PostgreSQL driver (postgresql://) — NOT asyncpg.
# ------------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/test_manager

# ------------------------------------------------------------------------------
# Logging Configuration
# ------------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
